    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.output;\n\n// إزالة markdown لو AI رجع ```json\nraw = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// تحويل النص إلى JSON\nconst order = JSON.parse(raw);\n\n// حفظ آخر منتج\nlet lastProduct = $json.last_product || \"\";\n\nif (order.Product && order.Product !== \"\") {\n  lastProduct = order.Product;\n}\n\n// لو العميل كتب كمية فقط\nif ((!order.Product || order.Product === \"\") && order.piece) {\n  order.Product = lastProduct;\n}\n\nreturn [\n{\njson: {\ndata: order.reply,\nProduct: order.Product,\nname: order.name,\nphone: order.phone,\naddress: order.address,\npiece: order.piece,\norder_complete: order.order_complete,\nlast_product: lastProduct\n}\n}\n];"
      },
