        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"recipient\": {\n    \"id\": \"{{ $('Edit Fields1').item.json.id }}\"\n  },\n  \"message\": {\n    \"text\": \"تم استلام طلبك ✅ سيتم التواصل معك قريبًا.\"\n  }\n}",
